# ─────────────────────────────────────
# DateDrop — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────

# MongoDB connection string (required for saving date plans)
# Option A: Local MongoDB
MONGODB_URL=mongodb://localhost:27017/datedrop

# Option B: MongoDB Atlas (cloud)
# MONGODB_URL=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/datedrop?retryWrites=true&w=majority

# Optional: Custom port (defaults to 3000)
# PORT=3000
