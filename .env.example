# ─────────────────────────────────────
# DateDrop — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────

# MongoDB connection string (required for saving date plans)
# Paste your connection string from MongoDB Atlas or local instance below.
# Local:  mongodb://localhost:27017/datedrop
# Atlas:  see https://www.mongodb.com/docs/atlas/getting-started/
MONGODB_URL=

# Optional: Custom port (defaults to 3000)
# PORT=3000
